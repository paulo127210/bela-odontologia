# ============================================================
#  Bela Odontologia — Variáveis de Ambiente (Supabase)
#  Copie este arquivo para .env na raiz do projeto
#  e preencha com os dados do seu projeto Supabase.
# ============================================================

# Encontre em: Supabase > Settings > Database > Connection string (URI)
# Formato: postgresql://postgres:[SUA-SENHA]@[HOST]:5432/postgres
DATABASE_URL=postgresql://postgres:SUASENHA@db.SEUPROJETO.supabase.co:5432/postgres

# Chave secreta do Flask (gere uma aleatória)
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
